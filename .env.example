# Copier ce fichier vers .env et remplir avec vos vraies valeurs (ne jamais committer .env)

# PostgreSQL (Neon, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optionnel : URL directe non-pooler (Prisma / certains outils)
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret pour les sessions / JWT (générer une chaîne aléatoire longue)
JWT_SECRET=""

# Mot de passe optionnel pour inscription / zones protégées
# REGISTRATION_ACCESS_PASSWORD=

# Email (Resend, etc.)
# RESEND_API_KEY=

# Clés API internes (ne pas mettre de vraies valeurs ici)
# LPT_GPT_API_KEY=
# UPLOADTHING_TOKEN=
# OPENAI_API_KEY=

# Google OAuth (Console Google Cloud → Credentials)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (choisir un mot de passe fort en prod)
# ADMIN_PASSWORD=
